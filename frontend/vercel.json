{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "openingfit.com" }],
      "destination": "https://www.openingfit.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://opening-fit.onrender.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
