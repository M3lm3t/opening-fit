# OpeningFit production launch environment template. Values below are safe
# placeholders only. Never commit a populated production environment file.

# Runtime and backend application URLs (backend).
APP_ENV=development
FRONTEND_URL=https://www.openingfit.com
FRONTEND_URL_WWW=https://www.openingfit.com
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://www.openingfit.com/account
CORS_ALLOWED_ORIGINS=https://openingfit.com,https://www.openingfit.com
# Add an exact preview HTTPS origin to the comma-separated list only when that
# deployment must call the backend. Wildcards are rejected.

# Master launch control (backend). False blocks only new checkout creation.
OPENINGFIT_SUBSCRIPTIONS_ENABLED=false

# Backend-only Supabase configuration. The service-role key must never use a
# VITE_ prefix or be present in a frontend deployment/build environment.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Backend-only Stripe configuration. Never expose these as VITE_ variables.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_OPENINGFIT_PLUS_MONTHLY_PRICE_ID=
STRIPE_OPENINGFIT_PLUS_ANNUAL_PRICE_ID=

# Optional founding first-year offer. Configure the coupon in Stripe as once-only.
OPENINGFIT_FOUNDING_ANNUAL_OFFER_ENABLED=false
STRIPE_OPENINGFIT_FOUNDING_ANNUAL_COUPON_ID=

# Public display amounts returned by /api/billing/config (GBP).
OPENINGFIT_PLUS_MONTHLY_PRICE_GBP=4.99
OPENINGFIT_PLUS_ANNUAL_PRICE_GBP=39.99
OPENINGFIT_FOUNDING_FIRST_YEAR_PRICE_GBP=29.99

# Frontend-safe configuration. The Supabase anon key is designed to be public;
# access control must still be enforced by RLS. VITE_API_BASE_URL may be left
# blank when production uses the same-origin backend proxy.
VITE_API_BASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPPORT_EMAIL=support@openingfit.com

# Stripe Checkout is created on the backend and hosted by Stripe, so this app
# does not currently consume a browser publishable key. Do not add the secret
# key to the frontend. Add a publishable-key variable only if Stripe.js is used.
