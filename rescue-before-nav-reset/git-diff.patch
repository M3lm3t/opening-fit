+/* Make report hero action buttons feel like working app controls */
+.openingReportHero button,
+.openingFitReport button,
+.reportHero button,
+.reportSummary button,
+#app-dashboard button {
+  touch-action: manipulation;
+}
+
+.openingReportHero button:hover,
+.openingFitReport button:hover,
+.reportHero button:hover,
+.reportSummary button:hover {
+  transform: translateY(-1px);
+}
+
+.openingReportHero button:active,
+.openingFitReport button:active,
+.reportHero button:active,
+.reportSummary button:active {
+  transform: translateY(0);
+}
+
+.openingReportHero button:focus-visible,
+.openingFitReport button:focus-visible,
+.reportHero button:focus-visible,
+.reportSummary button:focus-visible {
+  outline: 3px solid rgba(96, 165, 250, 0.45);
+  outline-offset: 3px;
+}
+
+/* Report hero links are now real app-action buttons */
+.reportHeroActions button.reportPrimaryLink,
+.reportHeroActions button.reportSecondaryLink {
+  appearance: none;
+  border: 0;
+  font: inherit;
+  cursor: pointer;
+  text-decoration: none;
+}
+
+.reportHeroActions button.reportPrimaryLink:hover,
+.reportHeroActions button.reportSecondaryLink:hover {
+  transform: translateY(-1px);
+}
+
+.reportHeroActions button.reportPrimaryLink:focus-visible,
+.reportHeroActions button.reportSecondaryLink:focus-visible {
+  outline: 3px solid rgba(96, 165, 250, 0.45);
+  outline-offset: 3px;
+}
+
+/* Make report hero action buttons reliably clickable */
+.reportHero,
+.reportHeroMain,
+.reportHeroActions {
+  position: relative;
+  z-index: 5;
